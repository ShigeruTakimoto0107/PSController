echo on
wait >
sendln ../macros/ps1/Burauza_Debug_Open.ps1
print cyan Edge起動中...
setvar URL https://www.google.com/
wait >
sendln ../macros/ps1/Burauza_Navigate.ps1 %URL%
print cyan Google通常検索にナビゲート...
wait >
sendln ../macros/ps1/Burauza_Google_Search.ps1 "横浜 ラーメン"
print cyan 横浜 ラーメンで検索...

wait >
../macros/ps1/Burauza_URL_Return.ps1
getvar URL
print green %URL%
sendln
wait >
sendln ../macros/ps1/Burauza_Navigate.ps1 %URL%
print cyan 取得したURLにナビゲート...
wait >
pause
exit
